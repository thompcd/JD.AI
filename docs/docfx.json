{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/**/*.csproj" ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "includePrivateMembers": false,
      "disableDefaultFilter": false,
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [
          "user-guide/**/*.md",
          "user-guide/**/toc.yml",
          "developer-guide/**/*.md",
          "developer-guide/**/toc.yml",
          "operations/**/*.md",
          "operations/**/toc.yml",
          "reference/**/*.md",
          "reference/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern", "template" ],
    "globalMetadata": {
      "_appName": "JD.AI",
      "_appTitle": "JD.AI",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.svg",
      "_appFooter": "<span>JD.AI &copy; 2025 &mdash; MIT License &middot; <a href='https://github.com/JerrettDavis/JD.AI'>GitHub</a> &middot; <a href='https://www.nuget.org/packages/JD.AI'>NuGet</a></span>",
      "_description": "AI-powered terminal assistant and multi-channel platform built on Microsoft Semantic Kernel. 14 providers, 17 tool categories, 33+ slash commands.",
      "_copyright": "Copyright &copy; 2025 Jerrett Davis. Licensed under the MIT License.",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/JerrettDavis/JD.AI",
        "branch": "main"
      },
      "_gitUrlPattern": "github",
      "_lang": "en",
      "_siteUrl": "https://jerrettdavis.github.io/JD.AI/"
    }
  }
}
