@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Add" />
            <MudText>Spawn New Agent</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_definition.Id" Label="Agent ID" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_definition.Provider" Label="Provider" Variant="Variant.Outlined"
                          HelperText="e.g. ollama, claude-code, copilot" />
            <MudTextField @bind-Value="_definition.Model" Label="Model" Variant="Variant.Outlined"
                          HelperText="e.g. ollama/qwen3:30b-instruct" />
            <MudTextField @bind-Value="_definition.SystemPrompt" Label="System Prompt" Variant="Variant.Outlined"
                          Lines="4" />
            <MudNumericField @bind-Value="_definition.MaxTurns" Label="Max Turns" Variant="Variant.Outlined" Min="1" Max="100" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SpawnAsync" Disabled="_spawning">
            @if (_spawning) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Spawn
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public GatewayApiClient Api { get; set; } = null!;

    private AgentDefinition _definition = new() { MaxTurns = 20 };
    private bool _spawning;

    private void Cancel() => MudDialog.Cancel();

    private async Task SpawnAsync()
    {
        if (string.IsNullOrWhiteSpace(_definition.Id)) return;
        _spawning = true;
        try
        {
            await Api.SpawnAgentAsync(_definition);
            Snackbar.Add($"Agent '{_definition.Id}' spawned", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally { _spawning = false; }
    }
}
